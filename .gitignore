# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this can be annoying for other developers.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used with a library, you may ignore it.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is database of dependencies and should be tracked.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is database of dependencies and should be tracked.
#pdm.lock

# PEP 582; modern alternative to virtualenv (e.g. pdm)
__pypackages__/

